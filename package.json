{
  "name": "oasis-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "lint": "eslint src tests next.config.mjs playwright.config.ts tailwind.config.ts vitest.config.ts --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "build": "next build",
    "start": "next start",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ui": "npm run build && playwright test --ui",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "lucide-react": "0.468.0",
    "next": "16.2.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "22.10.2",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "autoprefixer": "10.4.20",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
